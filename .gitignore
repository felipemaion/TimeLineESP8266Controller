bin/data/*.mp4
bin/data/*.avi
bin/data/*.mkv
bin/data/*.aif
bin/data/*.aiff
bin/data/*.wav
bin/data/*.mp3
*.mov
*.mp4
*.zip

# settings/estado de runtime gerados pelo app
bin/data/settings.xml

# preserva a estrutura da pasta data
!bin/data/.gitkeep

